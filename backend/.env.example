# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Supabase Postgres connection string
# Supabase dashboard -> Project Settings -> Database -> Connection string (URI, "Transaction" pooler)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].pooler.supabase.com:6543/postgres

# Simple shared password gate for the admin portal (dummy auth, POC only)
ADMIN_PASSWORD=change-me

# Comma-separated list of origins allowed to call this API (your Vercel frontend URL)
CORS_ORIGINS=http://localhost:5173

# Retrieval tuning
RETRIEVAL_TOP_K=6
CONFIDENCE_THRESHOLD=0.28
